# ============================================
# Identity Center 接入配置
# ============================================

# Identity Center 服务地址（根据实际情况修改）
IDENTITY_CENTER_URL=http://localhost:5000

# 从 Identity Center 管理后台获取的 Client ID
CLIENT_ID=c35aeca737a543e16bc5fb16bc6a4e2d

# 从 Identity Center 管理后台获取的 Client Secret
# 注意：在生产环境中，请从环境变量或安全的密钥管理服务获取
CLIENT_SECRET=your_client_secret_here

# 回调地址（必须与 Identity Center 注册的一致）
REDIRECT_URI=http://localhost:3001/callback

# 请求的权限范围（多个用空格分隔）
# 可选值: openid profile email
SCOPE=openid profile email

# 会话密钥（用于加密 session）
SESSION_SECRET=your_session_secret_here_change_in_production

# 应用端口
PORT=3001
